# Core AI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
OPENAI_DETECT_MODEL=gpt-4o-mini
GOOGLE_TRANSLATE_API_KEY=

# Retrieval tuning
RAG_TOP_K=8
RAG_MIN_SCORE=0.10
RAG_LEXICAL_FLOOR=0.10
RAG_INCLUDE_RAW=true
RAG_INCLUDE_KB=true

# Session logging (AES-256-GCM at rest)
# Provide a 32-byte key as base64/hex, or any passphrase (hashed to 32 bytes).
SESSION_ENCRYPTION_KEY=

# Optional web scraping
FIRECRAWL_API_KEY=
ADYPU_SCRAPE_URLS=https://adypu.edu.in/,https://adypu.edu.in/university-officials/,https://adypu.edu.in/admissions/,https://adypu.edu.in/placements/,https://adypu.edu.in/contact-us/

# Optional Instagram ingestion via Meta Graph API
META_GRAPH_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
IG_POST_LIMIT=25

# Optional Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=adypu

# Tavily live web search (free tier)
TAVILY_API_KEY=
